rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users: only own document
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // User org memberships: read own, write own (needed to sync orgIds field)
    match /userOrgs/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Organizations: only members can read/write
    match /organizations/{orgId} {
      allow read: if request.auth != null && isOrgMember(orgId);
      allow write: if request.auth != null && isOrgMember(orgId);

      // Org data subcollection
      match /data/{key} {
        allow read: if request.auth != null && isOrgMember(orgId);
        allow write: if request.auth != null && isOrgMember(orgId);
      }
    }

    // Helper: check if user belongs to the organization
    // Uses the orgIds array field in userOrgs document
    function isOrgMember(orgId) {
      let userOrgsDoc = get(/databases/$(database)/documents/userOrgs/$(request.auth.uid)).data;
      return orgId in userOrgsDoc.orgIds;
    }
  }
}
